{
  "name": "b017",
  "version": "0.0.0-b1",
  "description": "b017 — BOLT layer-1 token templates + off-chain scanner (mint/transfer/split/merge/melt). Pre-compiled contract; no sx compiler required at runtime.",
  "license": "SEE LICENSE IN LICENSE.txt",
  "keywords": [
    "bsv",
    "bitcoin",
    "bolt",
    "token",
    "layer-1",
    "fungible",
    "nft",
    "smart-contract"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BOLT-Association/b017.git"
  },
  "bugs": {
    "url": "https://github.com/BOLT-Association/b017/issues"
  },
  "homepage": "https://github.com/BOLT-Association/b017#readme",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "build:contract": "node scripts/build-contract.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@bsv/sdk": "^2.1.6"
  },
  "devDependencies": {
    "@bsv/sdk": "^2.1.6",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
}
